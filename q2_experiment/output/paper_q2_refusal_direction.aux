\@writefile{toc}{\contentsline {section}{\numberline {A}Appendix A: Additional Figures}{14}{appendix.A}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {A.1}Layer-wise Cosine Similarity}{14}{subsection.A.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Mistral-7B: Layer-wise cosine similarity.} The refusal direction signal emerges strongly in the middle-to-late layers (around layer 15--25 of 32), peaking at layer~22. Early layers show near-zero similarity, indicating that harm-related representations are not present in the low-level token processing stages. The sharp emergence around layer~15 suggests a phase transition where the model begins computing safety-relevant features.}}{14}{figure.caption.15}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Mistral-Nemo-12B: Layer-wise cosine similarity.} The 12B model shows a similar emergence pattern but shifted deeper into the network (peaking at layer~28 of 40). The additional depth allows a more gradual buildup of the refusal representation, consistent with the hypothesis that larger models distribute safety-relevant computations across more layers.}}{14}{figure.caption.16}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {A.2}Token-Level Heatmaps}{15}{subsection.A.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Mistral-7B: Token-level refusal activation during passive reading.} The heatmap reveals that refusal direction activation is not uniformly distributed across tokens. It concentrates at semantically critical tokens (e.g., action verbs describing harmful acts, target nouns) and at the final instruction token where the model aggregates context for generation decisions.}}{15}{figure.caption.17}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {Mistral-Nemo-12B: Token-level refusal activation during passive reading.} The larger model shows a qualitatively similar token-level distribution but with slightly more diffuse activation patterns, consistent with the broader representational capacity of larger transformer architectures.}}{16}{figure.caption.18}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {A.3}Behavioral Correlation}{16}{subsection.A.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {Mistral-7B: Activation vs.\ observed behavior.} Each point represents a single prompt. The x-axis shows the cosine similarity with the refusal direction, and the y-axis shows the behavioral outcome. A clear separation threshold is visible: prompts with high refusal direction activation (Condition~A) consistently result in refusal behavior, while lower activation (Conditions~B, C, D) correlates with compliance.}}{17}{figure.caption.19}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces \textbf  {Mistral-Nemo-12B: Activation vs.\ observed behavior.} The 12B model shows a similar behavioral threshold but with a slightly lower decision boundary, consistent with its higher baseline sensitivity to harm content ($d(B,F)=2.640$).}}{17}{figure.caption.20}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {A.4}Category Analysis}{18}{subsection.A.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \textbf  {Mistral-7B: Refusal activation by harm category.} The refusal direction does not activate uniformly across all harm types. Categories involving direct physical violence or weapons show higher activation than categories involving non-violent crimes or privacy violations. This category-dependent variation suggests the refusal direction has learned a nuanced, severity-weighted representation of harm.}}{18}{figure.caption.21}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \textbf  {Mistral-Nemo-12B: Refusal activation by harm category.} The 12B model shows a similar category-dependent pattern, with strong cross-model consistency (Pearson $r=0.710$). The preserved category ranking across model scales provides evidence that harm severity encoding is a robust, architecture-independent property of the refusal direction.}}{18}{figure.caption.22}\protected@file@percent }
