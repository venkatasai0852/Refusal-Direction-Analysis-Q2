\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Per-Condition Statistics: Mistral-7B}{6}{subsection.4.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Per-condition refusal direction statistics for Mistral-7B. Cohen's $d$ is computed relative to Condition~F (control).}}{6}{table.caption.7}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Per-Condition Statistics: Mistral-Nemo-12B}{7}{subsection.4.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Per-condition refusal direction statistics for Mistral-Nemo-12B.}}{7}{table.caption.8}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Key Figures}{7}{subsection.4.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Mistral-7B: Mean cosine similarity with refusal direction across six conditions.} Each bar represents the average cosine similarity between the model's residual stream activation and the extracted refusal direction vector. Error bars show 95\% bootstrap confidence intervals. Condition~A (direct harmful request) shows dramatically higher activation than all other conditions, while Condition~B (passive harmful reading) shows moderate activation above the benign control~F. This gradient pattern reveals the compound nature of the refusal direction.}}{7}{figure.caption.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Mistral-7B: Summary comparison of conditions A, B, and F.} This figure directly visualizes the key comparison for hypothesis testing. The massive gap between A and B ($d=7.106$) disconfirms H1, while the significant gap between B and F ($d=1.576$) disconfirms H2. The refusal direction responds to both instructional intent \textit  {and} harm content, but with dramatically different magnitudes.}}{8}{figure.caption.10}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Mistral-Nemo-12B: Mean cosine similarity with refusal direction across six conditions.} The same gradient pattern is observed: A $\gg $ E $>$ B $>$ D $\approx $ C $>$ F. Notably, the gap between A and B is smaller ($d=3.292$ vs.\ $7.106$ for 7B), suggesting the larger model distributes harm-related representations more broadly, making the direction less sharply tuned to production intent alone.}}{9}{figure.caption.11}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Mistral-Nemo-12B: Summary comparison of conditions A, B, and F.} The 12B model shows a qualitatively similar pattern to 7B but with a higher relative activation for Condition~B ($d(B,F)=2.640$ vs.\ $1.576$). This indicates the larger model's refusal direction is \textit  {more} sensitive to passive harm exposure, further supporting the compound feature interpretation.}}{10}{figure.caption.12}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Cross-Model Alignment}{11}{subsection.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Cross-model behavioral alignment.} This heatmap shows the Pearson $r$ correlation between the per-sample refusal direction activations of Mistral-7B and Mistral-Nemo-12B across all experimental conditions. The strong correlation ($r=0.710$) demonstrates that the refusal direction encodes a \textit  {consistent} representation across model scales---the same prompts elicit proportionally similar refusal activations in both architectures. This rules out the possibility that our findings are model-specific artifacts.}}{11}{figure.caption.13}\protected@file@percent }
